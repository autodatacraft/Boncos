        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "183267382063-2s1povn2c4gls268k247hjqvs5b2oseb.apps.googleusercontent.com",
        "EXPO_PUBLIC_BACKEND_URL": "https://boncos-backend.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
